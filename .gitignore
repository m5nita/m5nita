# Local scripts (not versioned) — exception: scripts/ci/ is used by GitHub Actions
# and must be versioned. Using `/scripts/*` (not `scripts/`) so that subdirectory
# re-inclusion works — git doesn't descend into excluded directories.
/scripts/*
!/scripts/ci/
