VITE_API_URL=http://localhost:3001

# Cloudflare Turnstile site key (public; use test key 1x00000000000000000000AA in dev/test)
VITE_TURNSTILE_SITE_KEY=1x00000000000000000000AA

# Sentry (leave VITE_SENTRY_DSN empty to disable runtime reporting)
VITE_SENTRY_DSN=

# Source-map upload (build time only; required for readable stack traces)
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
