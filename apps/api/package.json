{
  "name": "@m5nita/api",
  "private": true,
  "type": "module",
  "exports": {
    "./src/*": "./src/*"
  },
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx src/db/seed.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.1",
    "@m5nita/shared": "workspace:*",
    "@sentry/node": "^10.48.0",
    "@sentry/profiling-node": "^10.48.0",
    "better-auth": "^1.2.8",
    "drizzle-orm": "^0.41.0",
    "grammy": "^1.41.1",
    "hono": "^4.7.6",
    "hono-rate-limiter": "^0.5.3",
    "mercadopago": "^2.12.0",
    "postgres": "^3.4.5",
    "resend": "^6.10.0",
    "stripe": "^22.0.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "drizzle-kit": "^0.31.4",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.1.1"
  }
}
