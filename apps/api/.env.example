DATABASE_URL=postgresql://m5nita:m5nita@localhost:5432/m5nita

BETTER_AUTH_SECRET=generate-with-openssl-rand-base64-32
BETTER_AUTH_URL=http://localhost:3001

# Master key for encrypting PIX keys at rest. Generate: openssl rand -base64 32
PIX_ENCRYPTION_KEY=generate-with-openssl-rand-base64-32

# Payment gateway selection: stripe | mercadopago | infinitepay (default: mercadopago)
PAYMENT_GATEWAY=mercadopago

# Stripe (required when PAYMENT_GATEWAY=stripe)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# MercadoPago (required when PAYMENT_GATEWAY=mercadopago)
MERCADOPAGO_ACCESS_TOKEN=TEST-xxx
MERCADOPAGO_WEBHOOK_SECRET=your-webhook-secret

# InfinitePay (required when PAYMENT_GATEWAY=infinitepay in production)
# Operator's InfiniteTag without leading "$"
INFINITEPAY_HANDLE=your-infinitetag

FOOTBALL_DATA_API_KEY=xxx

GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

RESEND_API_KEY=re_xxxxxxxxxxxx

TELEGRAM_BOT_TOKEN=123456789:ABCdefGhIjKlMnOpQrStUvWxYz
TELEGRAM_WEBHOOK_SECRET=generate-random-secret-here
TELEGRAM_BOT_USERNAME=m5nita_bot

PORT=3001
ALLOWED_ORIGIN=http://localhost:5173

# Cloudflare Turnstile (server secret; use test key 1x0000000000000000000000000000000AA in dev/test)
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA
APP_URL=http://localhost:5173
NODE_ENV=development

# Sentry (leave empty to disable; environment is derived from NODE_ENV,
# release is injected at build time via the SOURCE_COMMIT Docker arg)
SENTRY_DSN=
